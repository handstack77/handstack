{
    "Serilog": {
        "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Error",
                "System": "Error"
            }
        },
        "Enrich": [ "FromLogContext" ],
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "../log/agent.log",
                    "rollingInterval": "Day",
                    "rollOnFileSizeLimit": true,
                    "buffered": true,
                    "fileSizeLimitBytes": 104857600,
                    "flushToDiskInterval": "00:00:05",
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    },
    "AllowedHosts": "*",
    "Agent": {
        "ServiceName": "handstack-agent",
        "ManagementHeaderName": "X-Management-Key",
        "ManagementKey": "CHANGE-THIS-KEY",
        "StateDirectoryPath": "state",
        "Targets": [
            {
                "TargetAckId": "ack-main",
                "Name": "ACK Main",
                "HostAccessID": "4d2f73707f482aa69580e637aef4f420a6149847b71696deb08b786114b1576b",
                "Description": "Primary ack process target",
                "ExecutablePath": "$HANDSTACK_HOME/app/ack.exe",
                "Arguments": "",
                "WorkingDirectory": "",
                "ProcessName": "ack",
                "PackageMakeCommand": "$HANDSTACK_HOME/tools/publish-package/publish-package make --publishpath=\"$HANDSTACK_HOME\" --includes=app,assemblies,modules\\dbclient,modules\\repository,modules\\function,modules\\transact,modules\\wwwroot --exclude=**/*.log,**/secrets*,**/node_modules,**/wwwroot/lib",
                "UseStatusProbeWhenProcessNotFound": true,
                "StatusProbeUrl": "http://localhost:8421/",
                "StatusProbeTimeoutSeconds": 3,
                "UseCommandBridge": false,
                "CommandBridgeUrl": "http://host.docker.internal:8584",
                "CommandBridgeHeaderName": "X-Bridge-Key",
                "CommandBridgeKey": "CHANGE-THIS-BRIDGE-KEY",
                "CommandBridgeTimeoutSeconds": 5,
                "StopTimeoutSeconds": 20,
                "KillEntireProcessTree": true,
                "EnvironmentVariables": {
                    "ACK_ENVIRONMENT": "Production"
                }
            }
        ],
        "HostBridge": {
            "Enabled": false,
            "HeaderName": "X-Bridge-Key",
            "BridgeKey": "CHANGE-THIS-BRIDGE-KEY"
        },
        "AuditLog": {
            "Enabled": false,
            "LogServerUrl": "http://localhost:8421/logger/api/log/insert",
            "RunningEnvironment": "D",
            "ApplicationID": "HDS",
            "ProjectID": "agent",
            "TransactionID": "targets",
            "ProgramName": "handstack-agent",
            "ProgramID": "agent",
            "UserIdHeaderName": "X-User-Id",
            "DeviceIdHeaderName": "X-Device-Id",
            "TimeoutSeconds": 3
        }
    },
    "Users": [
        {
            "EmailID": "admin@handstack.kr",
            "Password": "StrongKey123!",
            "UserName": "Administrator",
            "Roles": "Admin",
            "ExpiredAt": "",
            "CreatedAt": "2026-03-01T00:00:00Z"
        }
    ]
}

